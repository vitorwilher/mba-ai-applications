# Copie para .env e preencha. O .env NUNCA vai para o git (está no .gitignore).

# --- LLM (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- WhatsApp Cloud API (Meta) ---
# Obtidos em developers.facebook.com → seu app → WhatsApp → API Setup
WHATSAPP_TOKEN=EAAG...                 # token de acesso (temporário p/ testar; permanente p/ produção)
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_DESTINO=5521999999999         # número que recebe (com DDI+DDD, só dígitos)

# --- Fonte de dados (configurável) ---
# Exemplo padrão: série SGS do Banco Central (432 = meta Selic). Troque à vontade.
FONTE_URL=https://api.bcb.gov.br/dados/serie/bcdata.sgs.432/dados?formato=json
